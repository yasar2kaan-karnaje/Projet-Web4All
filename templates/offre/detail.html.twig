{% extends 'base.html.twig' %}

{% block title %}{{ offre.titre }} - Dépi'Stage{% endblock %}
{% block description %}{{ offre.titre }} chez {{ offre.entreprise_nom }} - Dépi'Stage{% endblock %}

{% block content %}
    <section class="section detail-page">
        <div class="container">
            <a href="/offres" class="back-link">&larr; Retour aux offres</a>

            {# Header #}
            <div class="detail-header">
                <div class="detail-company">{{ offre.entreprise_nom }}</div>
                <h1 class="detail-title">{{ offre.titre }}</h1>
                <div class="detail-meta">
                    <div class="detail-meta-item">
                        <span class="meta-label">Lieu</span>
                        <span class="meta-sep">:</span>
                        <span class="meta-value">{{ offre.lieu ?? 'Non précisé' }}</span>
                    </div>
                    <div class="detail-meta-item">
                        <span class="meta-label">Durée</span>
                        <span class="meta-sep">:</span>
                        <span class="meta-value">{{ offre.duree ?? 'Non précisée' }}</span>
                    </div>
                    {% if role != 'admin' %}
                    <div class="detail-meta-item">
                        <span class="meta-label">Candidats</span>
                        <span class="meta-sep">:</span>
                        <span class="meta-value">{{ offre.nb_candidatures }} personne(s)</span>
                    </div>
                    {% endif %}
                </div>
            </div>

            {# Description #}
            <div class="detail-section">
                <h3>Description du poste</h3>
                <p>{{ offre.description|nl2br }}</p>
            </div>

            {# Compétences #}
            {% if offre.competences %}
                <div class="detail-section">
                    <h3>Compétences requises</h3>
                    <div class="skills-list">
                        {% for skill in offre.competences|split(',') %}
                            <span class="skill-tag">{{ skill|trim }}</span>
                        {% endfor %}
                    </div>
                </div>
            {% endif %}

            {# Entreprise #}
            <div class="detail-section">
                <h3>À propos de l'entreprise</h3>
                <p>{{ offre.entreprise_description ?? offre.entreprise_nom }}</p>
                <a href="/entreprise/{{ offre.entreprise_id }}" class="btn btn-outline" style="margin-top: 16px;">
                    Voir la fiche entreprise &rarr;
                </a>
            </div>

            {# Formulaire de candidature (étudiant connecté uniquement) #}
            {% if is_logged_in and role == 'etudiant' %}
                <div class="detail-section">
                    <h3>Postuler à cette offre</h3>
                    {% if has_applied %}
                        <div class="alert alert-info">
                            Vous avez déjà postulé à cette offre. <a href="/etudiant/candidatures">Voir mes candidatures</a>
                        </div>
                    {% else %}
                        <form action="/offre/{{ offre.id }}/postuler" method="post" enctype="multipart/form-data">
                            <input type="hidden" name="csrf_token" value="{{ session.csrf_token }}">
                            <div class="form-group">
                                <label class="form-label" for="nom">Nom *</label>
                                <input type="text" name="nom" id="nom" class="form-input" required>
                                <span class="error-message" id="error-nom" style="color: red; font-size: 0.85em; display: none;">Ce champ est requis.</span>
                            </div>
                            <div class="form-group">
                                <label class="form-label" for="prenom">Prénom *</label>
                                <input type="text" name="prenom" id="prenom" class="form-input" required>
                                <span class="error-message" id="error-prenom" style="color: red; font-size: 0.85em; display: none;">Ce champ est requis.</span>
                            </div>
                            <div class="form-group">
                                <label class="form-label" for="courriel">Courriel *</label>
                                <input type="email" name="courriel" id="courriel" class="form-input" required>
                                <span class="error-message" id="error-courriel" style="color: red; font-size: 0.85em; display: none;">Veuillez entrer une adresse email valide.</span>
                            </div>
                            <div class="form-group">
                                <label class="form-label" for="cv">Votre CV *</label>
                                <input type="file" name="cv" id="cv" class="form-input" accept=".pdf,.doc,.docx,.odt,.rtf,.jpg,.png" required>
                                <span class="error-message" id="error-cv" style="color: red; font-size: 0.85em; display: none;">Fichier invalide ou trop volumineux.</span>
                            </div>
                            <div class="form-group">
                                <label class="form-label" for="message_recruteur">Message au recruteur *</label>
                                <textarea name="message_recruteur" id="message_recruteur" class="form-input form-textarea" placeholder="Expliquez pourquoi vous êtes le candidat idéal..." required></textarea>
                                <span class="error-message" id="error-message_recruteur" style="color: red; font-size: 0.85em; display: none;">Ce champ est requis.</span>
                            </div>
                            <div style="display: flex; gap: 12px; margin-top: 16px;">
                                <button type="submit" class="btn btn-primary btn-lg">Envoyer ma candidature</button>
                                {% if not in_wishlist %}
                                    <form action="/wishlist/add" method="post" style="display:inline;">
                                        <input type="hidden" name="csrf_token" value="{{ session.csrf_token }}">
                                        <input type="hidden" name="offre_id" value="{{ offre.id }}">
                                        <input type="hidden" name="redirect" value="/offre/{{ offre.id }}">
                                        <button type="submit" class="btn btn-outline btn-lg">Ajouter à la wishlist</button>
                                    </form>
                                {% endif %}
                            </div>
                        </form>
                    {% endif %}
                </div>
            {% elseif not is_logged_in %}
                <div class="detail-section">
                    <div class="alert alert-info">
                        <a href="/login">Connectez-vous</a> pour postuler à cette offre.
                    </div>
                </div>
            {% endif %}
        </div>

        {# Sticky Footer rémunération #}
        {% if offre.remuneration %}
            <div class="sticky-footer">
                <div>
                    <div class="salary-label">Rémunération</div>
                    <div class="salary">{{ offre.remuneration }}</div>
                </div>
                {% if is_logged_in and role == 'etudiant' and not has_applied %}
                    <a href="#postuler" class="btn btn-primary btn-lg">Postuler maintenant</a>
                {% endif %}
            </div>
        {% endif %}
    </section>
{% endblock %}
