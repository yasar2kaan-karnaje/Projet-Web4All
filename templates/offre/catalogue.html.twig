{% extends 'base.html.twig' %}

{% set active_page = 'offres' %}

{% block title %}Offres de stage - Dépi'Stage{% endblock %}
{% block description %}Découvrez toutes les offres de stage disponibles sur Dépi'Stage.{% endblock %}

{% block content %}
    {# Barre de recherche #}
    <div class="hero">
        <div class="hero-content">
            <div class="search-box">
                <form action="/offres" method="get" class="search-box-inline">
                    <div class="form-group" style="flex: 2;">
                        <input type="text" name="q" class="form-input" placeholder="Rechercher un stage, une entreprise ou une ville..." value="{{ search }}">
                    </div>
                    <button type="submit" class="btn btn-primary btn-lg">RECHERCHER</button>
                </form>
            </div>
        </div>
    </div>

    <section class="section" style="padding-top: 40px;">
        <div class="container">
            {# Carrousel statistiques (SFx11 - vrai carrousel avec navigation) #}
            <div class="stats-carousel-container" id="stats-carousel">
                <button class="carousel-arrow carousel-prev" id="carousel-prev" aria-label="Précédent">&#8249;</button>
                <div class="carousel-viewport">
                    <div class="carousel-track" id="carousel-track">
                        
                        <div class="carousel-slide">
                            <div class="stat-card carousel-card">
                                <div class="stat-number" style="color: var(--primary);">{{ stats.total }}</div>
                                <div class="stat-label">Offres disponibles</div>
                            </div>
                        </div>
                        
                        <div class="carousel-slide">
                            <div class="stat-card carousel-card">
                                <div class="stat-number" style="color: var(--primary);">{{ stats.avg_candidatures }}</div>
                                <div class="stat-label">Candidatures moy./offre</div>
                            </div>
                        </div>

                        <div class="carousel-slide">
                            <div class="stat-card carousel-card">
                                {% if stats.top_wishlist|length > 0 %}
                                    {% set top = stats.top_wishlist|first %}
                                    <div class="stat-number" style="color: var(--primary);">{{ top.nb }}</div>
                                    <div class="stat-label" title="{{ top.titre }}">Top liste : {{ top.titre|length > 20 ? top.titre|slice(0, 20) ~ '...' : top.titre }}</div>
                                {% else %}
                                    <div class="stat-number" style="color: var(--primary);">0</div>
                                    <div class="stat-label">Top Wish-list (Aucune)</div>
                                {% endif %}
                            </div>
                        </div>

                        <div class="carousel-slide">
                            <div class="stat-card carousel-card" style="padding: 16px;">
                                <div style="display: flex; gap: 24px; justify-content: center; align-items: flex-end; margin-bottom: 12px; width: 100%;">
                                    {% for rep in stats.repartition_duree|slice(0, 3) %}
                                        <div style="text-align: center;">
                                            <div class="stat-number" style="color: var(--primary); font-size: 1.8rem; margin-bottom: 4px; line-height: 1;">{{ rep.nb }}</div>
                                            <div style="font-size: 0.8rem; color: var(--text-secondary); font-weight: 600;">{{ rep.duree }}</div>
                                        </div>
                                    {% else %}
                                        <div class="stat-number" style="color: var(--primary);">0</div>
                                    {% endfor %}
                                </div>
                                <div class="stat-label" style="margin-top: 0;">Répartition par durée</div>
                            </div>
                        </div>

                    </div>
                </div>
                <button class="carousel-arrow carousel-next" id="carousel-next" aria-label="Suivant">&#8250;</button>
                <div class="carousel-dots" id="carousel-dots">
                    <span class="carousel-dot active" data-index="0"></span>
                    <span class="carousel-dot" data-index="1"></span>
                    <span class="carousel-dot" data-index="2"></span>
                    <span class="carousel-dot" data-index="3"></span>
                </div>
            </div>



            {# Grille des offres #}
            {% if offres is not empty %}
                <div class="grid grid-3">
                    {% for offre in offres %}
                        <article class="offer-card">
                            <div class="offer-card-header">
                                <div>
                                    <div class="offer-title">{{ offre.titre }}</div>
                                    <div class="offer-company">{{ offre.entreprise_nom }}</div>
                                </div>
                                {% if is_logged_in and role == 'etudiant' %}
                                    {% if offre.id in wishlist_ids %}
                                        <form action="/wishlist/remove" method="post" style="display:inline;">
                                            <input type="hidden" name="csrf_token" value="{{ session.csrf_token }}">
                                            <input type="hidden" name="offre_id" value="{{ offre.id }}">
                                            <input type="hidden" name="redirect" value="/offres?q={{ search }}&page={{ pagination.current_page }}">
                                            <button type="submit" class="wishlist-btn active" title="Retirer de la wishlist">&#9829;</button>
                                        </form>
                                    {% else %}
                                        <form action="/wishlist/add" method="post" style="display:inline;">
                                            <input type="hidden" name="csrf_token" value="{{ session.csrf_token }}">
                                            <input type="hidden" name="offre_id" value="{{ offre.id }}">
                                            <input type="hidden" name="redirect" value="/offres?q={{ search }}&page={{ pagination.current_page }}">
                                            <button type="submit" class="wishlist-btn" title="Ajouter à la wishlist">&#9825;</button>
                                        </form>
                                    {% endif %}
                                {% endif %}
                            </div>
                            <div class="offer-tags">
                                {% if offre.lieu %}<span class="tag">{{ offre.lieu }}</span>{% endif %}
                                {% if offre.duree %}<span class="tag">{{ offre.duree }}</span>{% endif %}
                            </div>
                            {% if offre.description %}
                                <p style="color: var(--text-secondary); font-size: 0.9rem; margin-bottom: 16px;">
                                    {{ offre.description|length > 120 ? offre.description|slice(0, 120) ~ '...' : offre.description }}
                                </p>
                            {% endif %}
                            <div class="offer-card-footer">
                                <a href="/offre/{{ offre.id }}" class="btn btn-dark btn-sm">Voir l'offre</a>
                            </div>
                        </article>
                    {% endfor %}
                </div>

                {# Pagination #}
                {% if pagination.pages > 1 %}
                    <div class="pagination">
                        {% if pagination.current_page > 1 %}
                            <a href="/offres?q={{ search }}&page={{ pagination.current_page - 1 }}" class="pagination-btn">&lsaquo;</a>
                        {% else %}
                            <span class="pagination-btn disabled">&lsaquo;</span>
                        {% endif %}

                        {% for i in 1..pagination.pages %}
                            <a href="/offres?q={{ search }}&page={{ i }}" class="pagination-btn{% if i == pagination.current_page %} active{% endif %}">{{ i }}</a>
                        {% endfor %}

                        {% if pagination.current_page < pagination.pages %}
                            <a href="/offres?q={{ search }}&page={{ pagination.current_page + 1 }}" class="pagination-btn">&rsaquo;</a>
                        {% else %}
                            <span class="pagination-btn disabled">&rsaquo;</span>
                        {% endif %}
                    </div>
                {% endif %}
            {% else %}
                <div style="text-align: center; padding: 60px 20px; color: var(--text-muted);">
                    <p style="font-size: 1.1rem;">Aucune offre trouvée{% if search %} pour « {{ search }} »{% endif %}.</p>
                </div>
            {% endif %}
        </div>
    </section>
{% endblock %}
