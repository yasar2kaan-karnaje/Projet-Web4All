<!DOCTYPE html>
<html lang="fr" data-theme="light">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{% block title %}Dépi'Stage{% endblock %}</title>
    <meta name="description" content="{% block description %}Dépi'Stage - Plateforme de recherche de stages pour étudiants CESI{% endblock %}">
    <meta name="keywords" content="{% block keywords %}stage, alternance, étudiant, CESI, ingénieur, entreprise, recrutement{% endblock %}">
    <link rel="icon" type="image/png" href="/css/../logo/depistage.png">
    <link rel="stylesheet" href="/css/styles.css">
    <link rel="stylesheet" href="/css/components.css">
    <link rel="stylesheet" href="/css/home.css">
    <link rel="stylesheet" href="/css/login.css">
    <link rel="stylesheet" href="/css/offres.css">
    <link rel="stylesheet" href="/css/admin.css">
    <link rel="stylesheet" href="/css/cookies.css">
    <link rel="stylesheet" href="/css/pages.css">
</head>

<body>
    {# === HEADER dynamique selon le rôle === #}
    <header class="header">
        <div class="header-inner">
            <a href="/" class="logo">
                <div class="logo-icon">
                    <img src="/logo/depistage.png" alt="Dépi'Stage Logo">
                </div>
                <div class="logo-text">
                    <span class="brand-name">Dépi'Stage</span>
                    {% if role == 'admin' %}
                        <span class="brand-tagline">Administration</span>
                    {% elseif role == 'pilote' %}
                        <span class="brand-tagline">Espace Pilote</span>
                    {% endif %}
                </div>
            </a>

            <nav class="nav-desktop">
                <ul>
                    {% if role == 'admin' %}
                        <li><a href="/admin" class="nav-link{% if active_page is defined and active_page == 'admin-dashboard' %} active{% endif %}">Dashboard</a></li>
                        <li><a href="/admin/pilotes" class="nav-link{% if active_page is defined and active_page == 'admin-pilotes' %} active{% endif %}">Pilotes</a></li>
                        <li><a href="/admin/etudiants" class="nav-link{% if active_page is defined and active_page == 'admin-etudiants' %} active{% endif %}">Étudiants</a></li>
                        <li><a href="/admin/entreprises" class="nav-link{% if active_page is defined and active_page == 'admin-entreprises' %} active{% endif %}">Entreprises</a></li>
                        <li><a href="/admin/offres" class="nav-link{% if active_page is defined and active_page == 'admin-offres' %} active{% endif %}">Offres</a></li>
                        <li><a href="/offres" class="nav-link{% if active_page is defined and active_page == 'offres' %} active{% endif %}">/Offres/</a></li>
                        <li><a href="/entreprises" class="nav-link{% if active_page is defined and active_page == 'entreprises' %} active{% endif %}">/Entreprises/</a></li>
                    {% elseif role == 'pilote' %}
                        <li><a href="/admin" class="nav-link{% if active_page is defined and active_page == 'admin-dashboard' %} active{% endif %}">Dashboard</a></li>
                        <li><a href="/admin/etudiants" class="nav-link{% if active_page is defined and active_page == 'admin-etudiants' %} active{% endif %}">Étudiants</a></li>
                        <li><a href="/admin/entreprises" class="nav-link{% if active_page is defined and active_page == 'admin-entreprises' %} active{% endif %}">Entreprises</a></li>
                        <li><a href="/admin/offres" class="nav-link{% if active_page is defined and active_page == 'admin-offres' %} active{% endif %}">Offres</a></li>
                        <li><a href="/offres" class="nav-link{% if active_page is defined and active_page == 'offres' %} active{% endif %}">/Offres/</a></li>
                        <li><a href="/entreprises" class="nav-link{% if active_page is defined and active_page == 'entreprises' %} active{% endif %}">/Entreprises/</a></li>
                        <li><a href="/pilote/candidatures" class="nav-link{% if active_page is defined and active_page == 'pilote-candidatures' %} active{% endif %}">Candidatures</a></li>
                    {% elseif role == 'etudiant' %}
                        {# Navigation Étudiant #}
                        <li><a href="/" class="nav-link{% if active_page is defined and active_page == 'home' %} active{% endif %}">Accueil</a></li>
                        <li><a href="/offres" class="nav-link{% if active_page is defined and active_page == 'offres' %} active{% endif %}">Offres</a></li>
                        <li><a href="/entreprises" class="nav-link{% if active_page is defined and active_page == 'entreprises' %} active{% endif %}">Entreprises</a></li>
                        <li><a href="/etudiant/candidatures" class="nav-link{% if active_page is defined and active_page == 'etudiant-candidatures' %} active{% endif %}">Mes candidatures</a></li>
                        <li><a href="/etudiant/wishlist" class="nav-link{% if active_page is defined and active_page == 'etudiant-wishlist' %} active{% endif %}">Wishlist</a></li>
                    {% else %}
                        {# Navigation Anonyme (non connecté) #}
                        <li><a href="/offres" class="nav-link{% if active_page is defined and active_page == 'offres' %} active{% endif %}">Offres de stage</a></li>
                        <li><a href="/entreprises" class="nav-link{% if active_page is defined and active_page == 'entreprises' %} active{% endif %}">Entreprises</a></li>
                        <li><a href="/mentions-legales" class="nav-link{% if active_page is defined and active_page == 'mentions' %} active{% endif %}">Mentions Légales</a></li>
                    {% endif %}
                </ul>
            </nav>

            <div class="header-actions">
                {% if is_logged_in %}
                    <div class="user-menu">
                        <button class="user-menu-toggle" id="user-menu-toggle">
                            <span class="user-avatar">{{ user.prenom|first|upper }}</span>
                            <span class="user-name">{{ user.prenom }}</span>
                        </button>
                        <div class="user-dropdown" id="user-dropdown">
                            <div class="user-dropdown-header">
                                <span class="user-avatar" style="width:36px;height:36px;">{{ user.prenom|first|upper }}</span>
                                <div>
                                    <div style="font-weight:600;">{{ user.prenom }} {{ user.nom }}</div>
                                    <div style="font-size:0.8rem;color:var(--text-muted);">{{ user.email }}</div>
                                </div>
                            </div>
                            <a href="/profil" class="user-dropdown-item">
                                Mon Profil
                            </a>
                            <a href="/logout" class="user-dropdown-item user-dropdown-logout">
                                Déconnexion
                            </a>
                        </div>
                    </div>
                {% else %}
                    <a href="/login" class="btn-connexion">CONNEXION</a>
                {% endif %}
                <button class="burger-menu" id="burger-menu" aria-label="Menu">
                    <span class="burger-line"></span>
                    <span class="burger-line"></span>
                    <span class="burger-line"></span>
                </button>
            </div>
        </div>
    </header>

    {# === CONTENU PRINCIPAL === #}
    <main class="main-content">
        {% block content %}{% endblock %}
    </main>

    {# === FOOTER === #}
    <footer class="footer">
        <div class="container">
            <div class="footer-content">
                <div class="footer-brand">
                    <a href="/" class="logo">
                        <div class="logo-icon">
                            <img src="/logo/depistage.png" alt="Dépi'Stage Logo">
                        </div>
                        <span>Dépi'Stage</span>
                    </a>
                    <p class="footer-text">Sans stage, t'es au chômage ! La plateforme de référence pour trouver votre stage idéal.</p>
                </div>
                <div class="footer-links">
                    <div class="footer-column">
                        <h4>Navigation</h4>
                        <ul>
                            <li><a href="/">Accueil</a></li>
                            <li><a href="/offres">Offres</a></li>
                            <li><a href="/entreprises">Entreprises</a></li>
                        </ul>
                    </div>
                    <div class="footer-column">
                        <h4>Légal</h4>
                        <ul>
                            <li><a href="/mentions-legales">Mentions légales</a></li>
                        </ul>
                    </div>
                </div>
            </div>
            <div class="footer-bottom">
                <p class="footer-copy">&copy; 2026 Dépi'Stage - CESI. Tous droits réservés.</p>
            </div>
        </div>
    </footer>

    {# === COOKIE BANNER === #}
    <div id="cookie-banner" class="cookie-banner">
        <div class="cookie-content">
            <h4>Confidentialité et cookies</h4>
            <p>Notre site utilise des cookies. Les cookies de session nous permettent de vous identifier de façon sécurisée. Vous avez le choix d'accepter tous les cookies (pour rester connecté plus longtemps) ou de les refuser. Les cookies strictement fonctionnels nécessaires au bon affichage seront conservés.</p>
        </div>
        <div class="cookie-actions">
            <button id="btn-accept-cookies" class="btn btn-primary">Tout accepter</button>
            <button id="btn-refuse-cookies" class="btn btn-outline" style="border-color: var(--error); color: var(--error);">Refuser</button>
        </div>
    </div>

    <script src="/js/navigation.js"></script>
    <script src="/js/cookies.js"></script>
    <script src="/js/validation.js"></script>
    <script src="/js/scroll.js"></script>
    <script src="/js/components.js"></script>
</body>

</html>
